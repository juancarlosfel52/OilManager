{
  "version": 8,
  "name": "OilManager — Permian Dark",
  "metadata": { "mapbox:autocompose": false },
  "sprite": "mapbox://sprites/mapbox/dark-v11",
  "glyphs": "mapbox://fonts/mapbox/{fontstack}/{range}.pbf",
  "sources": {
    "mapbox-streets": {
      "type": "vector",
      "url": "mapbox://mapbox.mapbox-streets-v8"
    },
    "mapbox-terrain": {
      "type": "vector",
      "url": "mapbox://mapbox.mapbox-terrain-v2"
    }
  },
  "layers": [

    {
      "id": "background",
      "type": "background",
      "paint": { "background-color": "#060810" }
    },

    {
      "id": "landcover-grass",
      "type": "fill",
      "source": "mapbox-streets",
      "source-layer": "landuse",
      "filter": ["match", ["get", "class"], ["grass", "park", "scrub", "farmland", "wood"], true, false],
      "paint": { "fill-color": "#0A0F1A", "fill-opacity": 0.9 }
    },

    {
      "id": "landcover-sand",
      "type": "fill",
      "source": "mapbox-streets",
      "source-layer": "landuse",
      "filter": ["match", ["get", "class"], ["sand", "rock"], true, false],
      "paint": { "fill-color": "#0D1018", "fill-opacity": 1 }
    },

    {
      "id": "national-park",
      "type": "fill",
      "source": "mapbox-streets",
      "source-layer": "landuse",
      "filter": ["==", ["get", "class"], "national_park"],
      "paint": { "fill-color": "#0B1520", "fill-opacity": 0.8 }
    },

    {
      "id": "water",
      "type": "fill",
      "source": "mapbox-streets",
      "source-layer": "water",
      "paint": { "fill-color": "#06111E" }
    },

    {
      "id": "water-shadow",
      "type": "line",
      "source": "mapbox-streets",
      "source-layer": "water",
      "paint": {
        "line-color": "#0A2030",
        "line-width": 1.5,
        "line-blur": 2
      }
    },

    {
      "id": "waterway",
      "type": "line",
      "source": "mapbox-streets",
      "source-layer": "waterway",
      "paint": {
        "line-color": "#07141F",
        "line-width": ["interpolate", ["linear"], ["zoom"], 8, 0.5, 14, 2]
      }
    },

    {
      "id": "terrain-contour",
      "type": "line",
      "source": "mapbox-terrain",
      "source-layer": "contour",
      "filter": ["==", ["get", "index"], 5],
      "paint": {
        "line-color": "#121828",
        "line-width": 0.5,
        "line-opacity": 0.6
      }
    },

    {
      "id": "building",
      "type": "fill",
      "source": "mapbox-streets",
      "source-layer": "building",
      "paint": {
        "fill-color": "#0D1020",
        "fill-outline-color": "#1A2035"
      }
    },

    {
      "id": "building-outline",
      "type": "line",
      "source": "mapbox-streets",
      "source-layer": "building",
      "paint": {
        "line-color": "#1E2438",
        "line-width": 0.6
      }
    },

    {
      "id": "road-path",
      "type": "line",
      "source": "mapbox-streets",
      "source-layer": "road",
      "filter": ["match", ["get", "class"], ["path", "pedestrian", "track"], true, false],
      "paint": {
        "line-color": "#131928",
        "line-width": 0.8,
        "line-dasharray": [2, 3]
      }
    },

    {
      "id": "road-minor-case",
      "type": "line",
      "source": "mapbox-streets",
      "source-layer": "road",
      "filter": ["match", ["get", "class"], ["service", "driveway"], true, false],
      "paint": {
        "line-color": "#0A0E1C",
        "line-width": ["interpolate", ["linear"], ["zoom"], 12, 1.5, 18, 4]
      }
    },

    {
      "id": "road-minor",
      "type": "line",
      "source": "mapbox-streets",
      "source-layer": "road",
      "filter": ["match", ["get", "class"], ["service", "driveway"], true, false],
      "paint": {
        "line-color": "#141828",
        "line-width": ["interpolate", ["linear"], ["zoom"], 12, 0.8, 18, 2.5]
      }
    },

    {
      "id": "road-street-case",
      "type": "line",
      "source": "mapbox-streets",
      "source-layer": "road",
      "filter": ["match", ["get", "class"], ["street", "street_limited"], true, false],
      "paint": {
        "line-color": "#0C1020",
        "line-width": ["interpolate", ["linear"], ["zoom"], 12, 3, 18, 9]
      }
    },

    {
      "id": "road-street",
      "type": "line",
      "source": "mapbox-streets",
      "source-layer": "road",
      "filter": ["match", ["get", "class"], ["street", "street_limited"], true, false],
      "paint": {
        "line-color": "#1A2040",
        "line-width": ["interpolate", ["linear"], ["zoom"], 12, 1.5, 18, 6]
      }
    },

    {
      "id": "road-secondary-case",
      "type": "line",
      "source": "mapbox-streets",
      "source-layer": "road",
      "filter": ["match", ["get", "class"], ["secondary", "tertiary"], true, false],
      "paint": {
        "line-color": "#0C1020",
        "line-width": ["interpolate", ["linear"], ["zoom"], 8, 1.5, 14, 7]
      }
    },

    {
      "id": "road-secondary",
      "type": "line",
      "source": "mapbox-streets",
      "source-layer": "road",
      "filter": ["match", ["get", "class"], ["secondary", "tertiary"], true, false],
      "paint": {
        "line-color": "#1C2445",
        "line-width": ["interpolate", ["linear"], ["zoom"], 8, 0.8, 14, 4]
      }
    },

    {
      "id": "road-primary-case",
      "type": "line",
      "source": "mapbox-streets",
      "source-layer": "road",
      "filter": ["==", ["get", "class"], "primary"],
      "paint": {
        "line-color": "#2A1E00",
        "line-width": ["interpolate", ["linear"], ["zoom"], 6, 2, 14, 10]
      }
    },

    {
      "id": "road-primary",
      "type": "line",
      "source": "mapbox-streets",
      "source-layer": "road",
      "filter": ["==", ["get", "class"], "primary"],
      "paint": {
        "line-color": "#3D2A00",
        "line-width": ["interpolate", ["linear"], ["zoom"], 6, 1, 14, 6]
      }
    },

    {
      "id": "road-motorway-case",
      "type": "line",
      "source": "mapbox-streets",
      "source-layer": "road",
      "filter": ["match", ["get", "class"], ["motorway", "trunk"], true, false],
      "paint": {
        "line-color": "#3D2800",
        "line-width": ["interpolate", ["linear"], ["zoom"], 4, 2, 14, 14],
        "line-join": "round"
      }
    },

    {
      "id": "road-motorway",
      "type": "line",
      "source": "mapbox-streets",
      "source-layer": "road",
      "filter": ["match", ["get", "class"], ["motorway", "trunk"], true, false],
      "paint": {
        "line-color": [
          "interpolate", ["linear"], ["zoom"],
          4, "#4A3200",
          10, "#7A5100",
          14, "#F5A623"
        ],
        "line-width": ["interpolate", ["linear"], ["zoom"], 4, 1, 14, 8],
        "line-join": "round"
      }
    },

    {
      "id": "road-rail",
      "type": "line",
      "source": "mapbox-streets",
      "source-layer": "road",
      "filter": ["match", ["get", "class"], ["major_rail", "minor_rail"], true, false],
      "paint": {
        "line-color": "#1A1E30",
        "line-width": 1,
        "line-dasharray": [5, 5]
      }
    },

    {
      "id": "road-label",
      "type": "symbol",
      "source": "mapbox-streets",
      "source-layer": "road",
      "filter": ["match", ["get", "class"], ["motorway", "trunk", "primary", "secondary"], true, false],
      "layout": {
        "symbol-placement": "line",
        "text-field": ["get", "name"],
        "text-font": ["DIN Pro Medium", "Arial Unicode MS Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 10, 9, 16, 13],
        "text-max-angle": 30
      },
      "paint": {
        "text-color": "#8A7040",
        "text-halo-color": "#060810",
        "text-halo-width": 1.5
      }
    },

    {
      "id": "boundary-state",
      "type": "line",
      "source": "mapbox-streets",
      "source-layer": "admin",
      "filter": ["==", ["get", "admin_level"], 4],
      "paint": {
        "line-color": "#2A3050",
        "line-width": 1,
        "line-dasharray": [4, 3]
      }
    },

    {
      "id": "boundary-country",
      "type": "line",
      "source": "mapbox-streets",
      "source-layer": "admin",
      "filter": ["==", ["get", "admin_level"], 2],
      "paint": {
        "line-color": "#3A4060",
        "line-width": 1.5
      }
    },

    {
      "id": "place-city",
      "type": "symbol",
      "source": "mapbox-streets",
      "source-layer": "place_label",
      "filter": ["==", ["get", "type"], "city"],
      "layout": {
        "text-field": ["get", "name"],
        "text-font": ["DIN Pro Bold", "Arial Unicode MS Bold"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 4, 10, 12, 16],
        "text-max-width": 8
      },
      "paint": {
        "text-color": "#C8A040",
        "text-halo-color": "#060810",
        "text-halo-width": 2
      }
    },

    {
      "id": "place-town",
      "type": "symbol",
      "source": "mapbox-streets",
      "source-layer": "place_label",
      "filter": ["match", ["get", "type"], ["town", "village"], true, false],
      "layout": {
        "text-field": ["get", "name"],
        "text-font": ["DIN Pro Regular", "Arial Unicode MS Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 8, 9, 14, 13]
      },
      "paint": {
        "text-color": "#6B7280",
        "text-halo-color": "#060810",
        "text-halo-width": 1.5
      }
    },

    {
      "id": "place-state",
      "type": "symbol",
      "source": "mapbox-streets",
      "source-layer": "place_label",
      "filter": ["==", ["get", "type"], "state"],
      "layout": {
        "text-field": ["get", "name"],
        "text-font": ["DIN Pro Medium", "Arial Unicode MS Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 4, 10, 8, 14],
        "text-transform": "uppercase",
        "text-letter-spacing": 0.15
      },
      "paint": {
        "text-color": "#3A4060",
        "text-halo-color": "#060810",
        "text-halo-width": 1
      }
    },

    {
      "id": "place-country",
      "type": "symbol",
      "source": "mapbox-streets",
      "source-layer": "place_label",
      "filter": ["==", ["get", "type"], "country"],
      "layout": {
        "text-field": ["get", "name"],
        "text-font": ["DIN Pro Bold", "Arial Unicode MS Bold"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 2, 10, 6, 18],
        "text-transform": "uppercase",
        "text-letter-spacing": 0.2
      },
      "paint": {
        "text-color": "#4A5070",
        "text-halo-color": "#060810",
        "text-halo-width": 2
      }
    },

    {
      "id": "poi-industrial",
      "type": "symbol",
      "source": "mapbox-streets",
      "source-layer": "poi_label",
      "filter": ["match", ["get", "maki"], ["industry", "fuel", "oil-well"], true, false],
      "layout": {
        "text-field": ["get", "name"],
        "text-font": ["DIN Pro Regular", "Arial Unicode MS Regular"],
        "text-size": 11,
        "text-max-width": 8,
        "text-offset": [0, 1.2]
      },
      "paint": {
        "text-color": "#F5A623",
        "text-halo-color": "#060810",
        "text-halo-width": 1.5
      }
    }

  ]
}
